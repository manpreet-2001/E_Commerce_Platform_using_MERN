# Set these when building the frontend for production (e.g. in Render / Vercel env).
# Do not commit real URLs; use placeholders or set only on the hosting platform.

# Backend API URL (required for production build)
REACT_APP_API_BASE=https://your-backend-api-url.com

# Optional: WebSocket URL for real-time updates (usually same as API URL)
# REACT_APP_WS_URL=https://your-backend-api-url.com
